---
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatPrice, getFeaturedProductsByCategory } from "../lib/products";

const pillars = [
  {
    title: "Mindset",
    text: "Reprogram your mind and beliefs",
    icon: "mind",
  },
  {
    title: "Healing",
    text: "Release, restore and recharge",
    icon: "lotus",
  },
  {
    title: "Manifestation",
    text: "Align with your desires and create",
    icon: "sun",
  },
  {
    title: "Well-Being",
    text: "Sleep, relax and find inner peace",
    icon: "moon",
  },
];

const audioProducts = getFeaturedProductsByCategory("audio");
const bookProducts = getFeaturedProductsByCategory("book");
---

<BaseLayout
  title="Your Preferred Life | Mindset Audio, Books and Guided Tools"
  description="Transform your mindset, elevate your energy and create the life you truly desire with audio sessions, books and practical digital resources."
>
  <section class="hero">
    <div class="hero-copy">
      <h1>
        You have the power to choose a different life.
        <span>Let's create it.</span>
      </h1>
      <p>Transform your mindset, elevate your energy and create the life you truly desire.</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#audio">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 10v4m4-7v10m4-13v16m4-11v6m4-8v10" />
          </svg>
          Browse Audio
        </a>
        <a class="btn btn-secondary" href="#books">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 5.5A3.5 3.5 0 0 1 8.5 2H19v17H8.5A3.5 3.5 0 0 0 5 22V5.5Zm0 0A3.5 3.5 0 0 1 8.5 2" />
          </svg>
          Explore Books
        </a>
      </div>
    </div>
    <div class="hero-image" aria-label="Woman standing at a sunlit coastline"></div>
  </section>

  <section class="pillars" aria-label="Resource categories">
    {pillars.map((pillar) => (
      <article>
        <span class={`pillar-icon pillar-${pillar.icon}`} aria-hidden="true"></span>
        <h2>{pillar.title}</h2>
        <p>{pillar.text}</p>
      </article>
    ))}
  </section>

  <section class="showcase" id="audio">
    <div class="section-intro">
      <p class="eyebrow">Featured Audio</p>
      <h2>Powerful audio to shift your mind and change your life.</h2>
      <a class="btn btn-dark" href="/#audio-library">View All Audio</a>
    </div>
    <div class="product-grid">
      {audioProducts.map((product) => (
        <article class="product-card audio-card">
          <div class="product-media">
            <img src={product.image} alt={`${product.title} cover image`} loading="lazy" />
            <button type="button" aria-label={`Play preview of ${product.title}`} class="play-button">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m9 7 8 5-8 5V7Z" />
              </svg>
            </button>
          </div>
          <div class="product-body">
            <h3>{product.title}</h3>
            <p>{product.type}</p>
            <div class="product-foot">
              <strong>{formatPrice(product)}</strong>
              <button
                type="button"
                class="checkout-button"
                data-product-slug={product.slug}
                aria-label={`Buy ${product.title}`}
              >
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M6.5 8.5h11l-.8 11H7.3l-.8-11Zm2.5 0a3 3 0 0 1 6 0" />
                </svg>
              </button>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="showcase" id="books">
    <div class="section-intro">
      <p class="eyebrow">Featured Books</p>
      <h2>Beautiful books to inspire, guide and support your journey.</h2>
      <a class="btn btn-dark" href="/#book-library">View All Books</a>
    </div>
    <div class="product-grid">
      {bookProducts.map((product) => (
        <article class="product-card book-card">
          <div class="product-media">
            <img src={product.image} alt={`${product.title} cover`} loading="lazy" />
          </div>
          <div class="product-body">
            <h3>{product.title}</h3>
            <p>{product.type}</p>
            <div class="product-foot">
              <strong>{formatPrice(product)}</strong>
              <button
                type="button"
                class="checkout-button"
                data-product-slug={product.slug}
                aria-label={`Buy ${product.title}`}
              >
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M6.5 8.5h11l-.8 11H7.3l-.8-11Zm2.5 0a3 3 0 0 1 6 0" />
                </svg>
              </button>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="testimonial" id="about">
    <div>
      <span aria-hidden="true">“</span>
      <blockquote>
        These audio sessions have truly transformed my mindset and my life. I feel more calm, confident and aligned every day.
      </blockquote>
      <p>– Sarah J.</p>
      <p class="stars" aria-label="Five star rating">★★★★★</p>
    </div>
  </section>

  <script>
    const checkoutButtons = document.querySelectorAll(".checkout-button");

    checkoutButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      button.addEventListener("click", async () => {
        const productSlug = button.dataset.productSlug;

        if (!productSlug || button.dataset.loading === "true") {
          return;
        }

        button.dataset.loading = "true";
        button.setAttribute("aria-busy", "true");

        try {
          const response = await fetch("/api/create-checkout", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ productSlug }),
          });
          const result = await response.json();

          if (!response.ok || !result.checkoutUrl) {
            throw new Error(result.error ?? "Unable to create checkout.");
          }

          window.location.href = result.checkoutUrl;
        } catch (error) {
          const message = error instanceof Error ? error.message : "Unable to create checkout.";
          window.alert(message);
        } finally {
          button.dataset.loading = "false";
          button.removeAttribute("aria-busy");
        }
      });
    });
  </script>
</BaseLayout>
