---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="mx-auto grid max-w-6xl gap-10 px-6 py-20 md:grid-cols-[1.15fr_0.85fr] md:items-center">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-brand">Digital tools for intentional living</p>
      <h1 class="mt-4 text-5xl font-bold tracking-tight text-slate-950 md:text-6xl">
        Build your preferred life with clearer choices.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
        A home for practical digital products, thoughtful resources, and essays about designing a life that fits.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="#products" class="rounded-md bg-brand px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-700">
          View Products
        </a>
        <a href="/blog" class="rounded-md border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-800 hover:border-slate-400">
          Read the Blog
        </a>
      </div>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-semibold text-slate-500">Project status</p>
      <ul class="mt-5 space-y-4 text-sm text-slate-700">
        <li class="flex gap-3"><span class="font-semibold text-brand">01</span> Astro is ready for fast pages and server routes.</li>
        <li class="flex gap-3"><span class="font-semibold text-brand">02</span> Tailwind CSS is connected for styling.</li>
        <li class="flex gap-3"><span class="font-semibold text-brand">03</span> Markdown blog posts live in content collections.</li>
        <li class="flex gap-3"><span class="font-semibold text-brand">04</span> Lemon Squeezy checkout helpers are scaffolded.</li>
      </ul>
    </div>
  </section>

  <section id="products" class="bg-white px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-bold tracking-tight text-slate-950">Products</h2>
        <p class="mt-3 text-slate-600">
          Add your Lemon Squeezy variant IDs to product cards and send customers into a secure checkout.
        </p>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {["Starter Guide", "Template Pack", "Premium Toolkit"].map((name) => (
          <article class="rounded-lg border border-slate-200 p-5">
            <h3 class="text-lg font-semibold text-slate-950">{name}</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">Replace this with a real digital product description.</p>
            <button
              class="mt-5 w-full rounded-md bg-slate-950 px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-800"
              data-variant-id=""
            >
              Buy Now
            </button>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
