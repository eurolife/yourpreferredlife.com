---
import BaseLayout from "./BaseLayout.astro";

const { title, description, pubDate, updatedDate, tags } = Astro.props;
---

<BaseLayout title={`${title} | Your Preferred Life`} description={description}>
  <article class="mx-auto max-w-3xl px-6 py-14">
    <a href="/blog" class="text-sm font-medium text-brand">Back to blog</a>
    <header class="mt-8 border-b border-slate-200 pb-8">
      <p class="text-sm text-slate-500">
        Published {pubDate.toLocaleDateString("en", { dateStyle: "long" })}
        {updatedDate && ` · Updated ${updatedDate.toLocaleDateString("en", { dateStyle: "long" })}`}
      </p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">{description}</p>
      {tags?.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {tags.map((tag: string) => (
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">{tag}</span>
          ))}
        </div>
      )}
    </header>
    <div class="prose prose-slate mt-8 max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
